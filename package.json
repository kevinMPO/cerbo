{
  "name": "cerbo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:local": "wrangler d1 execute cerbo --local --file db/schema.sql",
    "db:remote": "wrangler d1 execute cerbo --remote --file db/schema.sql",
    "hermes:bridge": "node hermes-bridge/server.mjs",
    "cf:dev": "next build && wrangler pages dev out --compatibility-flags nodejs_compat",
    "cf:deploy": "next build && wrangler pages deploy out"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "@xyflow/react": "^12.11.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.3.8",
    "lucide-react": "^0.417.0",
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.4",
    "wrangler": "^3.78.0"
  }
}
